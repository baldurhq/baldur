# Baldur environment template — copy to `.env` and fill in real values.
# NEVER commit the filled-in `.env`. See docs/runbooks/secure-deployment.md for
# the full secret classification (CRITICAL / IMPORTANT / OPTIONAL), key
# generation, and the validate_required_secrets() pre-flight gate.

# ─── CRITICAL (production startup aborts if missing) ─────────────────────────

# Deployment environment. Baldur expects `production` in deployed systems; a
# non-production value disables the CRITICAL-secret startup abort by design.
BALDUR_ENVIRONMENT=production

# Fernet key for recoverable PII encryption (AES-128-CBC). Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BALDUR_SECRETS_ENCRYPTION_KEY=

# Admin API-key credential (grants the Operator role on the admin server).
BALDUR_ADMIN_KEY=

# ─── IMPORTANT ───────────────────────────────────────────────────────────────

# Optional read-only admin key (grants the Viewer role).
BALDUR_ADMIN_READONLY_KEY=

# Set to 1 to allow Admin-tier operations on the admin server. Keep 0 otherwise.
BALDUR_ADMIN_UNLOCK=0

# Shared state for multi-worker deployments. Omit for the single-process
# in-memory fallback.
BALDUR_REDIS_URL=redis://localhost:6379/0
BALDUR_SECRETS_REDIS_PASSWORD=

# Signing key for the tamper-evident audit hash chain.
BALDUR_SECRETS_AUDIT_SIGNING_KEY=

# Database password (when using a SQL-backed repository / audit store).
BALDUR_SECRETS_DATABASE_PASSWORD=

# ─── TLS (enable for production traffic to Redis / DB / upstreams) ───────────

BALDUR_TLS_ENABLED=false
BALDUR_TLS_CERTIFICATE_PATH=
BALDUR_TLS_KEY_PATH=
BALDUR_TLS_CA_BUNDLE_PATH=
BALDUR_TLS_MIN_VERSION=TLSv1_2
BALDUR_TLS_VERIFY_MODE=CERT_REQUIRED

# ─── OPTIONAL (integrations) ─────────────────────────────────────────────────

# Slack webhook token for notifications (PRO notification tier).
BALDUR_SECRETS_SLACK_WEBHOOK_TOKEN=
